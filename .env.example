# Copy this file to .env and fill in real values. Do NOT commit secrets.

# Optional: URL to external backend that serves /books (leave empty to use DB/CSV)
MAIN_BACKEND_URL=

# Postgres/Neon DSN used by rebuild_models.py and analytics
DATABASE_URL=postgres://user:pass@localhost:5432/pustara

# Redis URL for social/trending/rate-limiting (optional)
REDIS_URL=redis://localhost:6379/0

# Local paths
MODEL_DIR=./pustara_models
BOOKS_CSV=./pustara_books_100.csv

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001

# Admin contact (no real mailbox here)
ADMIN_CONTACT_EMAIL=admin@pustara.local

# Optional health secret (if set, GET /health requires this)
HEALTH_SECRET=

# Recommendation cache TTL (seconds)
REC_CACHE_TTL=21600

# Backend pagination/timeouts
MAIN_BACKEND_PAGE_LIMIT=200
MAIN_BACKEND_MAX_PAGES=25
MAIN_BACKEND_TIMEOUT_S=15

# Chat rate limiting
CHAT_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_WINDOW=60
